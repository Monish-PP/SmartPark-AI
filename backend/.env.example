# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true
MONGO_DB_NAME=smartpark

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza_your_google_maps_api_key

# ── Edge AI ───────────────────────────────────────────────────────────────────
# Shared secret to authenticate incoming edge telemetry (must match occupancy-service)
EDGE_AI_SECRET=changeme-edge-secret
