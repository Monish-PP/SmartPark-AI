# ─────────────────────────────────────────────────────────────────────────────
# SmartPark AI — Edge Occupancy Service
# Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend Connection ────────────────────────────────────────────────────────
# Full URL of your Django backend API (no trailing slash)
DJANGO_API_URL=http://localhost:8000/api

# Secret key shared with Django (must match EDGE_AI_SECRET in backend/.env)
API_SECRET_KEY=changeme-super-secret-key

# ── Parking Lot Identity ──────────────────────────────────────────────────────
# The UUID/ID of the ParkingLot in MongoDB that this camera monitors
PARKING_ID=P001

# ── Camera Source ─────────────────────────────────────────────────────────────
# Options:
#   "0"                          → default webcam (USB/built-in)
#   "1"                          → second webcam
#   "rtsp://user:pass@IP:554/stream" → IP camera RTSP stream
#   "http://IP/video.mjpg"       → HTTP MJPEG stream
CAMERA_SOURCE=0

# ── Detection Parameters ──────────────────────────────────────────────────────
# Seconds between detection cycles (1 = ~real-time, 5 = relaxed)
DETECTION_INTERVAL_SEC=1.0

# YOLOv8 confidence threshold (lower = more detections, higher = fewer false positives)
CONFIDENCE_THRESHOLD=0.45

# Frames a slot must stay occupied/free before state flips (noise reduction)
HYSTERESIS_FRAMES=3

# ── Slot Configuration ────────────────────────────────────────────────────────
# Total number of parking slots visible to this camera
TOTAL_PARKING_SLOTS=20

# YOLO COCO class IDs to treat as vehicles (2=car, 3=motorcycle, 5=bus, 7=truck)
VEHICLE_CLASS_IDS=[2, 3, 5, 7]

# Optional: define exact slot bounding boxes in camera frame pixels
# Format: [[x1, y1, x2, y2, "slot_id"], ...]
# Leave empty ("") to use total-vehicle-count mode instead
# Example: SLOT_REGIONS_JSON=[[0,100,200,300,"A1"],[210,100,410,300,"A2"]]
SLOT_REGIONS_JSON=

# ── Reporting Behaviour ───────────────────────────────────────────────────────
# Minimum slot count change needed to trigger a backend update (0 = always)
MIN_CHANGE_TO_REPORT=0

# HTTP retry settings
MAX_RETRIES=3
RETRY_BACKOFF_SEC=2.0

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
LOG_LEVEL=INFO
